# ─────────────────────────────────────────────────────────────────────────────
# Copia este fichero como .env y rellena los valores reales.
# NUNCA subas el .env real a Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Seguridad Django ──────────────────────────────────────────────────────────
# Genera una clave aleatoria con:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-secreta-aleatoria

# En producción siempre False
DEBUG=False

# Tu dominio separado por comas (sin http/https)
ALLOWED_HOSTS=proyectobetterlife.duckdns.org

# ── Base de datos PostgreSQL (AWS RDS) ────────────────────────────────────────
DB_NAME=better_life_db
DB_USER=better_life_user
DB_PASSWORD=tu-contraseña-segura-aqui
# El endpoint lo ves en la consola de AWS → RDS → tu instancia → Endpoint
DB_HOST=tu-instancia.xxxxxxxxxx.eu-west-1.rds.amazonaws.com
DB_PORT=5432

# ── CORS (controla quién puede llamar a la API desde un navegador) ─────────────
# Orígenes permitidos separados por comas, con protocolo incluido
# Para la app móvil no es necesario, pero sí para el panel Swagger
CORS_ALLOWED_ORIGINS=https://proyectobetterlife.duckdns.org
# Pon True sólo en desarrollo/testing, nunca en producción
CORS_ALLOW_ALL_ORIGINS=False

# ── CSRF (necesario para el admin y Swagger bajo HTTPS) ───────────────────────
CSRF_TRUSTED_ORIGINS=https://proyectobetterlife.duckdns.org

# ── Gunicorn (opcional, ya tiene defaults en gunicorn.conf.py) ────────────────
PORT=8000
GUNICORN_WORKERS=2
